# Telegram bot token from @BotFather.
# Never commit a real token.
BOT_TOKEN=replace_me_with_botfather_token

# Local development database URL.
# Use localhost when running the bot outside Docker.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mafia_db

# Local development Redis URL.
# Use localhost when running the bot outside Docker.
REDIS_URL=redis://redis:6379/0

# Runtime environment.
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=DEBUG
