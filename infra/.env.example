# Telegram bot token from @BotFather.
# Never commit a real token.
BOT_TOKEN=replace_me_with_botfather_token

# Docker Compose database URL.
# Hostname "postgres" is the docker-compose service name.
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/mafia_db

# Docker Compose Redis URL.
# Hostname "redis" is the docker-compose service name.
REDIS_URL=redis://redis:6379/0

# Runtime environment.
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
